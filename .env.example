# Copy to .env for local development. Never commit the real .env file.

# --- Database ---
# Leave DATABASE_NAME unset locally -- config/database.yml already picks a
# distinct default per environment (music_streamer_development / _test), and
# setting it here would make development and test share one database.
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# --- Auth ---
# HMAC secret used to sign JWTs. Falls back to Rails' secret_key_base if unset.
JWT_SECRET=

# --- Object storage (S3-compatible: MinIO locally, GCS in production) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_AUDIO_BUCKET=audio
# MinIO needs path-style bucket addressing; GCS/AWS do not.
S3_FORCE_PATH_STYLE=true

# --- CORS ---
# Comma-separated list of allowed web/mobile client origins.
CORS_ORIGINS=http://localhost:5173
